#!/usr/bin/env bash
set -euo pipefail

# Generate a new ed25519 SSH key pair following the standard:
#   - one key per usage (project × platform × device)
#   - encrypted with a passphrase (store in your password manager)
#   - per-host Include block written to ~/.ssh/config.d/<name>

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m  %s\n' "$*"; }

read -r -p "Key name (e.g. github_personal, aws_acme): " name
[[ -z "$name" ]] && { warn "name required"; exit 1; }

read -r -p "Comment / email: " comment
[[ -z "$comment" ]] && { warn "comment required"; exit 1; }

read -r -p "Host pattern (e.g. github.com, github.com-work, *.acme.internal): " host
[[ -z "$host" ]] && { warn "host required"; exit 1; }

read -r -p "Real hostname (blank = same as Host; set this for aliases, e.g. github.com): " hostname

key_path="$HOME/.ssh/$name"
config_path="$HOME/.ssh/config.d/$name"

if [[ -e "$key_path" ]]; then
  warn "$key_path already exists. Aborting."
  exit 1
fi

mkdir -p "$HOME/.ssh/config.d"
chmod 700 "$HOME/.ssh" "$HOME/.ssh/config.d"

log "Generating ed25519 key (you'll be asked for a passphrase — use Dashlane)..."
ssh-keygen -t ed25519 -C "$comment" -f "$key_path"

log "Writing ~/.ssh/config.d/$name..."
{
  printf 'Host %s\n' "$host"
  [[ -n "$hostname" ]] && printf '  HostName %s\n' "$hostname"
  printf '  IdentityFile ~/.ssh/%s\n' "$name"
  printf '  IdentitiesOnly yes\n'
} > "$config_path"
chmod 600 "$config_path"

log "Adding key to ssh-agent + Keychain..."
ssh-add --apple-use-keychain "$key_path"

log "Public key (copied to clipboard):"
pbcopy < "$key_path.pub"
cat "$key_path.pub"
